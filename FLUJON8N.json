      "parameters": {
        "jsCode": "const raw = $input.first().json.content.parts[0].text;\nconst cleaned = raw.replace(/```json|```/g, '').trim();\nconst verdict = JSON.parse(cleaned);\n\n// Escapar comillas simples para SQL\nconst escape = (str) => str ? str.replace(/'/g, \"''\") : null;\n\nreturn [{\n  json: {\n    ...verdict,\n    alerta: escape(verdict.alerta),\n    mensaje_hospital: escape(verdict.mensaje_hospital),\n    mensaje_gestor: escape(verdict.mensaje_gestor)\n  }\n}];"
      },
